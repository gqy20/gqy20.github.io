{
  "name": "gqy20-portfolio",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "homepage": "https://gqy20.github.io",
  "scripts": {
    "dev": "npm run godot:ensure && vite",
    "build": "npm run godot:ensure && vite build",
    "build:web": "vite build",
    "godot:export": "bash scripts/export-godot-web.sh",
    "godot:ensure": "bash scripts/ensure-godot-web.sh",
    "godot:check": "node scripts/check-godot-web.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "sync-blog": "node scripts/sync-blog.js",
    "perf:check": "node scripts/performance-analysis.js",
    "perf:quick": "lighthouse https://home.gqy20.top --chrome-flags=\"--headless --no-sandbox --disable-dev-shm-usage\" --only-categories=performance",
    "perf:full": "lighthouse https://home.gqy20.top --chrome-flags=\"--headless --no-sandbox --disable-dev-shm-usage\" --output=html --output-path=./lighthouse-report.html",
    "perf:mobile": "lighthouse https://home.gqy20.top --chrome-flags=\"--headless --no-sandbox --disable-dev-shm-usage\" --form-factor=mobile --output=json --output-path=./lighthouse-mobile.json",
    "perf:desktop": "lighthouse https://home.gqy20.top --chrome-flags=\"--headless --no-sandbox --disable-dev-shm-usage\" --form-factor=desktop --output=json --output-path=./lighthouse-desktop.json",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "mermaid": "^11.16.0",
    "motion": "^12.42.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "feed": "^5.2.1",
    "gh-pages": "^6.1.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.9",
    "postcss": "^8.5.6",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "tailwindcss": "^4.1.16",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
